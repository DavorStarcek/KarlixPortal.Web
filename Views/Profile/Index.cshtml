@model KarlixPortal.Web.Models.UserProfileViewModel

@{
    ViewData["Title"] = "Moj profil";
}

<h1 class="mb-3">Moj profil</h1>

<div class="row">
    <div class="col-md-4 mb-3">
        <div class="card">
            <div class="card-header">
                Osnovni podaci
            </div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-4">Ime</dt>
                    <dd class="col-sm-8">@Model.Name</dd>

                    <dt class="col-sm-4">Email</dt>
                    <dd class="col-sm-8">@Model.Email</dd>

                    <dt class="col-sm-4">Tenant</dt>
                    <dd class="col-sm-8">
                        @if (string.IsNullOrWhiteSpace(Model.Tenant))
                        {
                            <span class="text-muted">(nema tenanta)</span>
                        }
                        else if (Model.Tenant == "00000000-0000-0000-0000-000000000000")
                        {
                            <span class="badge bg-secondary">Global</span>
                        }
                        else
                        {
                            <span class="badge bg-info text-dark">@Model.Tenant</span>
                        }
                    </dd>

                    <dt class="col-sm-4">Role</dt>
                    <dd class="col-sm-8">
                        @if (Model.Roles.Any())
                        {
                            foreach (var r in Model.Roles)
                            {
                                <span class="badge bg-primary me-1">@r</span>
                            }
                        }
                        else
                        {
                            <span class="text-muted">(nema definiranih rola)</span>
                        }
                    </dd>
                </dl>
            </div>
        </div>
    </div>

    <div class="col-md-8 mb-3">
        <div class="card">
            <div class="card-header">
                Claimovi
            </div>
            <div class="card-body p-0">
                @if (Model.Claims == null || !Model.Claims.Any())
                {
                    <div class="p-3 text-muted">Nema claimova za prikaz.</div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-sm table-striped mb-0">
                            <thead>
                                <tr>
                                    <th>Claim type</th>
                                    <th>Vrijednost</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var c in Model.Claims)
                                {
                                    <tr>
                                        <td class="text-muted">@c.Type</td>
                                        <td>@c.Value</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
