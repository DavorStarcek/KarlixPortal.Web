@model IEnumerable<KarlixPortal.Web.Models.SsoAppViewModel>

@{
    ViewData["Title"] = "SSO aplikacije";
}

<h1 class="mb-3">SSO aplikacije</h1>
<p class="text-muted mb-4">
    Odaberite aplikaciju kojoj želite pristupiti. Dostupnost ovisi o vašim rolama i tenantu.
</p>

@if (Model == null || !Model.Any())
{
    <div class="alert alert-info">
        Trenutno nemate nijednu dostupnu aplikaciju.
    </div>
}
else
{
    <div class="row row-cols-1 row-cols-md-3 g-3">
        @foreach (var app in Model)
        {
            var disabled = !app.IsEnabled;
            <div class="col">
                <div class="card h-100 @(disabled ? "border-secondary-subtle" : "")">
                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title">
                            @if (!string.IsNullOrWhiteSpace(app.Icon))
                            {
                                <span class="me-1">@app.Icon</span>
                            }
                            @app.Name
                        </h5>

                        @if (!string.IsNullOrWhiteSpace(app.Description))
                        {
                            <p class="card-text text-muted">@app.Description</p>
                        }

                        <div class="mt-auto">
                            @if (disabled)
                            {
                                <span class="badge bg-secondary mb-2">Uskoro</span>
                                <p class="text-muted small mb-0">
                                    Ova aplikacija još nije dostupna u vašem okruženju.
                                </p>
                            }
                            else
                            {
                                <a class="btn btn-sm btn-primary"
                                   href="@app.Url"
                                   target="_blank"
                                   rel="noopener noreferrer">
                                    Otvori aplikaciju
                                </a>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}
