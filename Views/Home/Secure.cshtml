@using System.Security.Claims

@{
    ViewData["Title"] = "Secure zona";
}

<h2>@ViewData["Title"]</h2>

@if (User?.Identity?.IsAuthenticated == true)
{
    <p>Prijavljen si kao: <strong>@User.Identity.Name</strong></p>

    <h4>Claimovi</h4>
    <table class="table table-striped table-bordered">
        <thead>
            <tr>
                <th>Claim type</th>
                <th>Value</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var claim in User.Claims)
            {
                <tr>
                    <td>@claim.Type</td>
                    <td>@claim.Value</td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <p>Nisi prijavljen.</p>
}
